{
    "name": "laravel/user-discounts",
    "version": "1.0.0",
    "description": "A Laravel package for user-level discounts with stacking and audits.",
    "type": "laravel-package",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "LaravelUserDiscounts\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "LaravelUserDiscounts\\UserDiscountsServiceProvider"
            ]
        }
    },
    "require": {
        "php": "^8.2",
        "illuminate/database": ">=10.0",
        "illuminate/support": ">=10.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "phpunit/phpunit": ">=10.0"
    }
}